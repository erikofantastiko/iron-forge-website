---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Iron Forge - Finally. A Workout App That Gets It."
    description="The workout tracking app built for serious lifters. Track drop sets, supersets, myo-reps, and progressive overload with precision. No fluff. No fake AI. Just powerful training features."
    canonicalUrl="https://ironforge.app/"
>
    <Fragment slot="head">
        <!-- Additional SEO -->
        <meta name="keywords" content="workout app, fitness tracker, drop sets, supersets, myo-reps, progressive overload, gym app, iOS workout app" />
        <meta property="og:url" content="https://ironforge.app/" />
        <meta name="twitter:url" content="https://ironforge.app/" />

        <!-- Structured Data (JSON-LD) -->
        <script type="application/ld+json" is:inline>
        {
            "@context": "https://schema.org",
            "@type": "SoftwareApplication",
            "name": "Iron Forge",
            "applicationCategory": "HealthApplication",
            "operatingSystem": "iOS",
            "offers": {
                "@type": "Offer",
                "price": "0",
                "priceCurrency": "USD",
                "availability": "https://schema.org/PreOrder"
            },
            "description": "A workout tracking app built for serious lifters. Track drop sets, supersets, myo-reps, and progressive overload with precision.",
            "url": "https://ironforge.app",
            "logo": "https://ironforge.app/Logo.png",
            "author": {
                "@type": "Person",
                "name": "Erik"
            }
        }
        </script>
    </Fragment>

    <div class="container">
        <!-- Logo -->
        <div class="logo">
            <picture>
                <source srcset="/Logo.webp" type="image/webp" />
                <img src="/Logo.png" alt="Iron Forge Logo" width="44" height="44" />
            </picture>
            <span>IRON FORGE</span>
        </div>

        <!-- Hero Statement -->
        <div class="hero">
            <h1 class="finally">
                FINALLY.<br />
                A WORKOUT APP<br />
                <span class="red">THAT GETS IT.</span>
            </h1>
            <p class="tagline">
                Built for lifters who use drop sets, supersets, and
                myo-reps. No fluff. No fake AI. Just the advanced features serious lifters actually need.
            </p>
        </div>

        <!-- Feature Highlights -->
        <div class="features">
            <div class="feature">
                <span class="feature-icon">✓</span>
                <div class="feature-text">
                    <strong>Native drop set & superset tracking</strong>
                    <span>Log complex training techniques properly</span>
                </div>
            </div>
            <div class="feature">
                <span class="feature-icon">✓</span>
                <div class="feature-text">
                    <strong>Progressive overload visualization</strong>
                    <span>Track your strength gains over time</span>
                </div>
            </div>
            <div class="feature">
                <span class="feature-icon">✓</span>
                <div class="feature-text">
                    <strong>Auto-calculated training volume</strong>
                    <span>Stop doing math, focus on lifting</span>
                </div>
            </div>
            <div class="feature">
                <span class="feature-icon">✓</span>
                <div class="feature-text">
                    <strong>Apple Health recovery integration</strong>
                    <span>Smart recovery metrics from your data</span>
                </div>
            </div>
        </div>

        <!-- Waitlist Form - Kit Embed -->
        <script src="https://f.convertkit.com/ckjs/ck.5.js"></script>
        <form
            action="https://app.kit.com/forms/8869648/subscriptions"
            class="seva-form formkit-form"
            method="post"
            data-sv-form="8869648"
            data-uid="f1beae323b"
            data-format="inline"
            data-version="5"
            data-options='{"settings":{"after_subscribe":{"action":"message","success_message":"You&apos;re on the list! We&apos;ll notify you when Iron Forge launches."}}}'
        >
            <div data-style="clean">
                <ul
                    class="formkit-alert formkit-alert-error"
                    data-element="errors"
                    data-group="alert"
                >
                </ul>
                <div
                    data-element="fields"
                    data-stacked="false"
                    class="seva-fields formkit-fields"
                >
                    <div class="formkit-field">
                        <input
                            class="formkit-input"
                            name="email_address"
                            aria-label="Email Address"
                            placeholder="Enter your email"
                            required=""
                            type="email"
                        />
                    </div>
                    <button
                        data-element="submit"
                        class="formkit-submit"
                    >
                        <div class="formkit-spinner">
                            <div></div><div></div><div></div>
                        </div>
                        <span>Join Waitlist</span>
                    </button>
                </div>
            </div>
        </form>
        <p class="form-note">
            <strong>Be among the first to experience Iron Forge.</strong><br>
            Launching soon on iOS. No spam, just launch updates.
        </p>

        <!-- Footer -->
        <div class="footer">
            <div class="footer-about">
                <strong>Built by Erik</strong>
                <span class="footer-credentials">— Lifter, Dad & Pilot</span>
            </div>
            <div class="footer-links">
                <a href="/privacy" class="footer-link" aria-label="Privacy Policy">Privacy</a>
                <span class="divider" aria-hidden="true">|</span>
                <a
                    href="https://www.instagram.com/ironforge.app/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="instagram-link"
                    aria-label="Follow Iron Forge on Instagram"
                >
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                    >
                        <path
                            d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                        ></path>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</Layout>

<style>
    /* Page-specific container */
    .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 60px 24px;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    /* Logo animation */
    .logo {
        margin-bottom: 80px;
        opacity: 0;
        animation: fadeIn 0.6s ease forwards;
    }

    /* Hero */
    .hero {
        margin-bottom: 80px;
    }

    .finally {
        font-family: "Bebas Neue", sans-serif;
        font-size: clamp(3.5rem, 12vw, 7rem);
        line-height: 1.05;
        letter-spacing: 0.04em;
        opacity: 0;
        animation: slideUp 0.8s ease forwards 0.2s;
    }

    .finally .red {
        color: var(--red);
    }

    .tagline {
        font-size: 1.1rem;
        color: var(--gray);
        margin-top: 24px;
        max-width: 480px;
        line-height: 1.6;
        opacity: 0;
        animation: fadeIn 0.8s ease forwards 0.6s;
    }

    /* Features */
    .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
        margin-bottom: 60px;
        opacity: 0;
        animation: fadeIn 0.8s ease forwards 0.8s;
    }

    .feature {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 20px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .feature:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(230, 57, 70, 0.3);
        transform: translateY(-2px);
    }

    .feature-icon {
        color: var(--red);
        font-size: 1.2rem;
        font-weight: 600;
        flex-shrink: 0;
    }

    .feature-text {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .feature-text strong {
        color: #fff;
        font-size: 0.95rem;
        font-weight: 500;
        line-height: 1.4;
    }

    .feature-text span {
        color: var(--gray);
        font-size: 0.85rem;
        line-height: 1.4;
    }

    /* Waitlist Form */
    .formkit-form {
        background-color: transparent;
    }

    .formkit-fields {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin: 0;
        opacity: 0;
        animation: fadeIn 0.8s ease forwards 1s;
    }

    .formkit-field {
        flex: 1;
        min-width: 200px;
        margin: 0;
    }

    .formkit-input {
        color: #fff;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 8px;
        font-weight: 400;
        padding: 16px 20px;
        width: 100%;
        font-size: 1rem;
        font-family: "Inter", sans-serif;
        outline: none;
        transition: border-color 0.2s, background 0.2s, transform 0.2s, box-shadow 0.2s;
    }

    .formkit-input::placeholder {
        color: var(--gray);
        transition: color 0.2s;
    }

    .formkit-input:hover {
        background: rgba(255, 255, 255, 0.07);
        border-color: rgba(255, 255, 255, 0.25);
    }

    .formkit-input:focus {
        border-color: var(--red);
        background: rgba(255, 255, 255, 0.08);
        outline: 2px solid var(--red);
        outline-offset: 2px;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(230, 57, 70, 0.15);
    }

    .formkit-input:focus::placeholder {
        color: rgba(136, 136, 136, 0.6);
    }

    .formkit-submit {
        padding: 16px 32px;
        font-size: 0.95rem;
        font-weight: 500;
        font-family: "Inter", sans-serif;
        background: var(--red);
        color: #fff;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        margin: 0;
    }

    .formkit-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(230, 57, 70, 0.3);
    }

    .formkit-submit:focus {
        outline: 2px solid var(--red);
        outline-offset: 3px;
    }

    .formkit-submit:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        transform: none;
    }

    /* Kit form alerts */
    .formkit-alert {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .formkit-alert:empty {
        display: none;
    }

    .formkit-alert-success {
        background: rgba(230, 57, 70, 0.15);
        border: 1px solid var(--red);
        border-radius: 8px;
        padding: 16px 24px;
        color: #fff;
        font-size: 1rem;
        margin-bottom: 12px;
    }

    .formkit-alert-error {
        background: rgba(255, 100, 100, 0.15);
        border: 1px solid #ff6b6b;
        border-radius: 8px;
        padding: 16px 24px;
        color: #ff6b6b;
        font-size: 0.9rem;
        margin-bottom: 12px;
    }

    .form-note {
        width: 100%;
        font-size: 0.8rem;
        color: var(--gray);
        margin-top: 16px;
    }

    .form-note strong {
        color: var(--red);
        font-weight: 500;
    }

    /* Footer */
    .footer {
        margin-top: auto;
        padding-top: 80px;
        font-size: 0.85rem;
        color: var(--gray);
        opacity: 0;
        animation: fadeIn 0.8s ease forwards 1.2s;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .footer-about {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .footer-about strong {
        color: #fff;
        font-weight: 500;
        font-size: 0.9rem;
    }

    .footer-credentials {
        color: var(--gray);
        font-size: 0.85rem;
    }

    .footer-links {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .footer-link {
        color: var(--gray);
        text-decoration: none;
        transition: color 0.2s;
    }

    .footer-link:hover {
        color: var(--red);
        text-decoration: none;
    }

    .divider {
        margin: 0 8px;
        color: rgba(136, 136, 136, 0.5);
    }

    .instagram-link {
        color: var(--gray);
        transition: color 0.2s, transform 0.2s;
        display: flex;
        align-items: center;
    }

    .instagram-link:hover {
        color: var(--red);
        transform: scale(1.1);
    }

    .instagram-link:focus,
    .footer-link:focus {
        outline: 2px solid var(--red);
        outline-offset: 3px;
        border-radius: 4px;
    }

    /* Mobile */
    @media (max-width: 600px) {
        .container {
            padding: 40px 20px;
        }

        .logo {
            margin-bottom: 60px;
        }

        .logo img {
            width: 36px;
            height: 36px;
        }

        .hero {
            margin-bottom: 60px;
        }

        .features {
            grid-template-columns: 1fr;
        }

        .feature {
            padding: 16px;
        }
    }

    @media (max-width: 400px) {
        .formkit-submit {
            padding: 16px 24px;
        }

        .finally {
            font-size: 3rem;
        }

        .feature-text strong {
            font-size: 0.9rem;
        }

        .feature-text span {
            font-size: 0.8rem;
        }
    }
</style>
