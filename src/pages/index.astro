---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Iron Forge - Finally. A Workout App That Gets It."
    description="The workout tracking app built for serious lifters. Track drop sets, supersets, myo-reps, and progressive overload with precision. No fluff. No fake AI. Just powerful training features."
    canonicalUrl="https://ironforge.app/"
>
    <Fragment slot="head">
        <!-- Additional SEO -->
        <meta name="keywords" content="workout app, fitness tracker, drop sets, supersets, myo-reps, progressive overload, gym app, iOS workout app" />
        <meta property="og:url" content="https://ironforge.app/" />
        <meta name="twitter:url" content="https://ironforge.app/" />

        <!-- Structured Data (JSON-LD) -->
        <script type="application/ld+json" is:inline>
        {
            "@context": "https://schema.org",
            "@type": "SoftwareApplication",
            "name": "Iron Forge",
            "applicationCategory": "HealthApplication",
            "operatingSystem": "iOS",
            "offers": [
                {
                    "@type": "Offer",
                    "price": "7.99",
                    "priceCurrency": "EUR",
                    "availability": "https://schema.org/PreOrder"
                },
                {
                    "@type": "Offer",
                    "price": "69.99",
                    "priceCurrency": "EUR",
                    "availability": "https://schema.org/PreOrder"
                }
            ],
            "description": "A workout tracking app built for serious lifters. Track drop sets, supersets, myo-reps, and progressive overload with precision.",
            "url": "https://ironforge.app",
            "logo": "https://ironforge.app/Logo.png",
            "author": {
                "@type": "Person",
                "name": "Erik"
            }
        }
        </script>
    </Fragment>

    <div class="container">
        <!-- Logo -->
        <div class="logo">
            <picture>
                <source srcset="/Logo.webp" type="image/webp" />
                <img src="/Logo.png" alt="Iron Forge Logo" width="44" height="44" />
            </picture>
            <span>IRON FORGE</span>
        </div>

        <!-- Hero Statement -->
        <div class="hero">
            <span class="badge">
                <span class="badge-dot" aria-hidden="true"></span>
                Launching soon · iOS
            </span>
            <h1 class="finally">
                FINALLY.<br />
                A WORKOUT APP<br />
                <span class="red">THAT GETS IT.</span>
            </h1>
            <p class="tagline">
                Built for lifters who use drop sets, supersets, and
                myo-reps. No fluff. No fake AI. Just the advanced features serious lifters actually need.
            </p>
        </div>

        <!-- Feature Highlights -->
        <div class="features">
            <div class="feature">
                <span class="feature-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M6.5 6.5 L6.5 17.5" />
                        <path d="M17.5 6.5 L17.5 17.5" />
                        <path d="M3 9 L3 15" />
                        <path d="M21 9 L21 15" />
                        <path d="M6.5 12 L17.5 12" />
                    </svg>
                </span>
                <div class="feature-text">
                    <strong>Track how you actually train</strong>
                    <span>Drop sets, supersets, myo-reps, and giant sets — logged exactly as you programme them, not how a beginner app thinks you train</span>
                </div>
            </div>
            <div class="feature">
                <span class="feature-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 17 9 11 13 15 21 7" />
                        <polyline points="15 7 21 7 21 13" />
                    </svg>
                </span>
                <div class="feature-text">
                    <strong>See your actual progress</strong>
                    <span>Estimated 1RM, weight and volume progression charts per exercise. Personal records tracked automatically — weight, e1RM and volume PRs</span>
                </div>
            </div>
            <div class="feature">
                <span class="feature-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 12 H7 L9 7 L12 17 L14 12 L16 14 H21" />
                    </svg>
                </span>
                <div class="feature-text">
                    <strong>HRV-based recovery scoring</strong>
                    <span>Recovery score from Apple Health data — HRV, sleep, and resting heart rate combined into a single daily readiness number</span>
                </div>
            </div>
            <div class="feature">
                <span class="feature-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 17 A8 8 0 0 1 20 17" />
                        <path d="M12 17 L16 9" />
                        <circle cx="12" cy="17" r="1.2" fill="currentColor" stroke="none" />
                    </svg>
                </span>
                <div class="feature-text">
                    <strong>RPE logging per set</strong>
                    <span>Log rate of perceived exertion on every set. No guesswork — just honest data about how hard you actually worked</span>
                </div>
            </div>
        </div>

        <!-- Pricing -->
        <section class="pricing" aria-labelledby="pricing-heading">
            <h2 id="pricing-heading" class="pricing-heading">Pricing at launch</h2>
            <div class="pricing-grid">
                <div class="price-card">
                    <span class="price-label">Monthly</span>
                    <div class="price-amount">
                        <span class="price-currency">€</span>7.99
                        <span class="price-period">/month</span>
                    </div>
                    <span class="price-note">Cancel anytime.</span>
                </div>
                <div class="price-card price-card-featured">
                    <span class="price-tag">Best value</span>
                    <span class="price-label">Yearly · save 27%</span>
                    <div class="price-amount">
                        <span class="price-currency">€</span>69.99
                        <span class="price-period">/year</span>
                    </div>
                    <span class="price-note">Works out to €5.83/month.</span>
                </div>
            </div>
        </section>

        <!-- Waitlist Form - Kit Embed -->
        <script src="https://f.convertkit.com/ckjs/ck.5.js"></script>
        <form
            action="https://app.kit.com/forms/8869648/subscriptions"
            class="seva-form formkit-form"
            method="post"
            data-sv-form="8869648"
            data-uid="f1beae323b"
            data-format="inline"
            data-version="5"
            data-options='{"settings":{"after_subscribe":{"action":"message","success_message":"You&apos;re on the list! We&apos;ll notify you when Iron Forge launches."}}}'
        >
            <div data-style="clean">
                <ul
                    class="formkit-alert formkit-alert-error"
                    data-element="errors"
                    data-group="alert"
                >
                </ul>
                <div
                    data-element="fields"
                    data-stacked="false"
                    class="seva-fields formkit-fields"
                >
                    <div class="formkit-field">
                        <input
                            class="formkit-input"
                            name="email_address"
                            aria-label="Email Address"
                            placeholder="you@example.com"
                            required=""
                            type="email"
                        />
                    </div>
                    <button
                        data-element="submit"
                        class="formkit-submit"
                    >
                        <div class="formkit-spinner">
                            <div></div><div></div><div></div>
                        </div>
                        <span>Join Waitlist</span>
                    </button>
                </div>
            </div>
        </form>
        <p class="form-note">No spam. Just launch updates.</p>

        <!-- Footer -->
        <div class="footer">
            <div class="footer-row">
                <div class="footer-about">
                    <strong>Built by Erik</strong>
                    <span class="footer-credentials">Lifter, dad &amp; pilot — based in Austria</span>
                </div>
                <div class="footer-links">
                    <a href="/privacy" class="footer-link" aria-label="Privacy Policy">Privacy</a>
                    <span class="divider" aria-hidden="true">·</span>
                    <a href="/legal" class="footer-link" aria-label="Legal Notice">Legal</a>
                    <span class="divider" aria-hidden="true">·</span>
                    <a
                        href="https://www.instagram.com/ironforge.app/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="instagram-link"
                        aria-label="Follow Iron Forge on Instagram"
                    >
                        <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            aria-hidden="true"
                        >
                            <path
                                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                            ></path>
                        </svg>
                    </a>
                </div>
            </div>
            <div class="footer-legal">
                © 2026 Iron Forge · Alland, Austria
            </div>
        </div>
    </div>
</Layout>

<style>
    /* Container */
    .container {
        max-width: 960px;
        margin: 0 auto;
        padding: 60px 24px;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    /* Logo */
    .logo {
        margin-bottom: 80px;
        opacity: 0;
        animation: fadeIn 0.6s ease forwards;
    }

    /* Hero */
    .hero {
        margin-bottom: 72px;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        margin-bottom: 24px;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--red);
        background: var(--red-soft);
        border: 1px solid rgba(230, 57, 70, 0.3);
        border-radius: 999px;
        opacity: 0;
        animation: fadeIn 0.6s ease forwards 0.1s;
    }

    .badge-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--red);
        box-shadow: 0 0 8px var(--red-glow);
        animation: pulse 2.4s ease-in-out infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.55; transform: scale(0.82); }
    }

    .finally {
        font-family: "Bebas Neue", sans-serif;
        font-size: clamp(3.5rem, 12vw, 7rem);
        line-height: 1.02;
        letter-spacing: 0.02em;
        opacity: 0;
        animation: slideUp 0.8s ease forwards 0.2s;
    }

    .finally .red {
        color: var(--red);
        text-shadow: 0 0 40px var(--red-glow);
    }

    .tagline {
        font-size: 1.125rem;
        color: var(--text-secondary);
        margin-top: 28px;
        max-width: 560px;
        line-height: 1.6;
        opacity: 0;
        animation: fadeIn 0.8s ease forwards 0.6s;
    }

    /* Features */
    .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 16px;
        margin-bottom: 60px;
        opacity: 0;
        animation: fadeIn 0.8s ease forwards 0.8s;
    }

    .feature {
        display: flex;
        align-items: flex-start;
        gap: 14px;
        padding: 22px;
        background: var(--surface-1);
        border: 1px solid var(--surface-border);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
        transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
    }

    .feature:hover {
        background: var(--surface-2);
        border-color: rgba(230, 57, 70, 0.4);
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .feature-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: var(--red-soft);
        color: var(--red);
        flex-shrink: 0;
    }

    .feature-icon svg {
        width: 20px;
        height: 20px;
    }

    .feature-text {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .feature-text strong {
        color: #fff;
        font-size: 0.98rem;
        font-weight: 600;
        line-height: 1.35;
        letter-spacing: -0.01em;
    }

    .feature-text span {
        color: var(--text-secondary);
        font-size: 0.88rem;
        line-height: 1.55;
    }

    /* Pricing */
    .pricing {
        margin-bottom: 48px;
        opacity: 0;
        animation: fadeIn 0.8s ease forwards 0.9s;
    }

    .pricing-heading {
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.1rem;
        letter-spacing: 0.2em;
        color: var(--text-muted);
        margin-bottom: 16px;
        text-transform: uppercase;
    }

    .pricing-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 16px;
    }

    .price-card {
        position: relative;
        padding: 24px;
        background: var(--surface-1);
        border: 1px solid var(--surface-border);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .price-card-featured {
        border-color: rgba(230, 57, 70, 0.55);
        box-shadow: var(--shadow-red);
        background: linear-gradient(180deg, var(--surface-1), rgba(230, 57, 70, 0.06));
    }

    .price-tag {
        position: absolute;
        top: -10px;
        right: 16px;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        padding: 4px 10px;
        background: var(--red);
        color: #fff;
        border-radius: 999px;
        box-shadow: var(--shadow-sm);
    }

    .price-label {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .price-amount {
        font-family: "Bebas Neue", sans-serif;
        font-size: 2.6rem;
        line-height: 1;
        letter-spacing: 0.02em;
        color: var(--text-primary);
        display: flex;
        align-items: baseline;
        gap: 2px;
    }

    .price-currency {
        font-size: 1.5rem;
        color: var(--text-secondary);
        margin-right: 2px;
    }

    .price-period {
        font-family: "Inter", sans-serif;
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--text-muted);
        margin-left: 6px;
    }

    .price-note {
        font-size: 0.85rem;
        color: var(--text-secondary);
    }

    /* Waitlist Form */
    .formkit-form {
        background-color: transparent;
    }

    .formkit-fields {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin: 0;
        opacity: 0;
        animation: fadeIn 0.8s ease forwards 1s;
    }

    .formkit-field {
        flex: 1;
        min-width: 200px;
        margin: 0;
    }

    .formkit-input {
        color: #fff;
        background: var(--surface-1);
        border: 1px solid var(--surface-border-strong);
        border-radius: var(--radius-md);
        font-weight: 400;
        padding: 16px 20px;
        width: 100%;
        font-size: 1rem;
        font-family: "Inter", sans-serif;
        outline: none;
        transition: border-color 0.2s, background 0.2s, transform 0.2s, box-shadow 0.2s;
    }

    .formkit-input::placeholder {
        color: var(--text-muted);
        transition: color 0.2s;
    }

    .formkit-input:hover {
        background: var(--surface-2);
        border-color: rgba(255, 255, 255, 0.2);
    }

    .formkit-input:focus {
        border-color: var(--red);
        background: var(--surface-2);
        outline: 2px solid var(--red);
        outline-offset: 2px;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(230, 57, 70, 0.2);
    }

    .formkit-input:focus::placeholder {
        color: rgba(122, 122, 128, 0.6);
    }

    .formkit-submit {
        padding: 16px 32px;
        font-size: 0.95rem;
        font-weight: 600;
        letter-spacing: 0.01em;
        font-family: "Inter", sans-serif;
        background: linear-gradient(135deg, var(--red), var(--red-deep));
        color: #fff;
        border: none;
        border-radius: var(--radius-md);
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s, filter 0.2s;
        margin: 0;
    }

    .formkit-submit:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-red);
        filter: brightness(1.05);
    }

    .formkit-submit:focus {
        outline: 2px solid var(--red);
        outline-offset: 3px;
    }

    .formkit-submit:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        transform: none;
    }

    /* Kit form alerts */
    .formkit-alert {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .formkit-alert:empty {
        display: none;
    }

    .formkit-alert-success {
        background: var(--red-soft);
        border: 1px solid var(--red);
        border-radius: var(--radius-md);
        padding: 16px 24px;
        color: #fff;
        font-size: 1rem;
        margin-bottom: 12px;
    }

    .formkit-alert-error {
        background: rgba(255, 100, 100, 0.15);
        border: 1px solid #ff6b6b;
        border-radius: var(--radius-md);
        padding: 16px 24px;
        color: #ff6b6b;
        font-size: 0.9rem;
        margin-bottom: 12px;
    }

    .form-note {
        width: 100%;
        font-size: 0.82rem;
        color: var(--text-muted);
        margin-top: 14px;
    }

    /* Footer */
    .footer {
        margin-top: auto;
        padding-top: 48px;
        margin-top: 80px;
        border-top: 1px solid var(--surface-border);
        font-size: 0.85rem;
        color: var(--text-muted);
        opacity: 0;
        animation: fadeIn 0.8s ease forwards 1.2s;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .footer-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .footer-about {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .footer-about strong {
        color: #fff;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .footer-credentials {
        color: var(--text-muted);
        font-size: 0.82rem;
    }

    .footer-links {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .footer-link {
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.2s;
    }

    .footer-link:hover {
        color: var(--red);
        text-decoration: none;
    }

    .divider {
        color: rgba(122, 122, 128, 0.4);
    }

    .instagram-link {
        color: var(--text-muted);
        transition: color 0.2s, transform 0.2s;
        display: inline-flex;
        align-items: center;
        margin-left: 4px;
    }

    .instagram-link:hover {
        color: var(--red);
        transform: scale(1.1);
    }

    .instagram-link:focus-visible,
    .footer-link:focus-visible {
        outline: 2px solid var(--red);
        outline-offset: 3px;
        border-radius: 4px;
    }

    .footer-legal {
        font-size: 0.78rem;
        color: var(--text-muted);
        opacity: 0.75;
    }

    /* Mobile */
    @media (max-width: 600px) {
        .container {
            padding: 40px 20px;
        }

        .logo {
            margin-bottom: 60px;
        }

        .logo img {
            width: 36px;
            height: 36px;
        }

        .hero {
            margin-bottom: 60px;
        }

        .finally {
            letter-spacing: 0.04em;
        }

        .features {
            grid-template-columns: 1fr;
        }

        .feature {
            padding: 18px;
        }

        .pricing-grid {
            grid-template-columns: 1fr;
        }

        .footer-row {
            flex-direction: column;
            align-items: flex-start;
            gap: 12px;
        }
    }

    @media (max-width: 400px) {
        .formkit-submit {
            padding: 16px 24px;
        }

        .finally {
            font-size: 3rem;
        }

        .feature-text strong {
            font-size: 0.92rem;
        }

        .feature-text span {
            font-size: 0.83rem;
        }

        .price-amount {
            font-size: 2.3rem;
        }
    }
</style>
